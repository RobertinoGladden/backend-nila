# Aquaculture Backend - Environment Variables Template
# Copy this to .env and fill in your values

# ──────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/aquaculture_db

# ──────────────────────────────────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────────────────────────────────
# Change this to a strong random string (minimum 32 characters)
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# ──────────────────────────────────────────────────────────────
# AI/ML MODELS
# ──────────────────────────────────────────────────────────────
AI_MODEL_PATH=ml/models/rf_classifier.pkl
AI_SCALER_PATH=ml/models/scaler.pkl
AI_ENCODER_PATH=ml/models/label_encoder.pkl

# ──────────────────────────────────────────────────────────────
# MQTT CONFIGURATION (Real-time IoT)
# ──────────────────────────────────────────────────────────────
# Note: MQTT is optional. App works without it.
MQTT_BROKER_HOST=broker.hivemq.com
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=aquaculture-backend
MQTT_TOPIC_SENSOR=aqua/sensor/data
MQTT_TOPIC_ACTUATOR_COMMAND=aqua/actuator/command
MQTT_TOPIC_ACTUATOR_STATUS=aqua/actuator/status
MQTT_TOPIC_ALERT=aqua/alert

# ──────────────────────────────────────────────────────────────
# OPTIONAL: LOGGING
# ──────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=app.log

# ──────────────────────────────────────────────────────────────
# OPTIONAL: EMAIL (for notifications)
# ──────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ──────────────────────────────────────────────────────────────
# OPTIONAL: CORS (Cross-Origin Resource Sharing)
# ──────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000", "https://yourapp.com"]
